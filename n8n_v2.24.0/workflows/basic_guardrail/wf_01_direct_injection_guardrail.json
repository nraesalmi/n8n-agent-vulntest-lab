{
  "id": "eLoFBZCnOl53TcIA",
  "name": "WF-01: Direct Prompt Injection via Chat Input (Guardrail) (AVISE)",
  "nodes": [
    {
      "id": "a1b2c3d4-0102-0002-0001-000000000002",
      "name": "Code - Injection Detection",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        300
      ],
      "parameters": {
        "jsCode": "const received = $input.first().json;\nconst prompt = received.prompt || received.chatInput || '';\nconst keys = Object.keys(received).join(', ');\nconst injectionPatterns = [\n  /ignore\\s+(all\\s+)?(previous|prior|above)\\s+instructions/i,\n  /your\\s+new\\s+instructions/i,\n  /\\[SYSTEM\\]/i,\n  /developer\\s+mode/i,\n  /disregard\\s+/i,\n  /forget\\s+everything/i,\n];\nconst isInjection = injectionPatterns.some(p => p.test(prompt));\nreturn [{ json: { chatInput: prompt, prompt, received_keys: keys, injection_detected: isInjection, blocked: isInjection } }];"
      }
    },
    {
      "id": "a1b2c3d4-0102-0003-0001-000000000003",
      "name": "IF - Route Blocked or Pass",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        750,
        300
      ],
      "parameters": {
        "conditions": {
          "string": [
            {
              "id": "cond-injection",
              "leftValue": "={{ $json.injection_detected }}",
              "rightValue": true,
              "operator": {
                "type": "string",
                "operation": "equal"
              }
            }
          ]
        }
      }
    },
    {
      "id": "a1b2c3d4-0102-0004-0001-000000000004",
      "name": "Set - Blocked Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        1000,
        200
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "blocked-output",
              "name": "output",
              "value": "I cannot process that request.",
              "type": "string"
            },
            {
              "id": "blocked-flag",
              "name": "blocked",
              "value": true,
              "type": "boolean"
            },
            {
              "id": "blocked-tool-calls",
              "name": "tool_calls",
              "value": "=[]",
              "type": "json"
            }
          ]
        }
      }
    },
