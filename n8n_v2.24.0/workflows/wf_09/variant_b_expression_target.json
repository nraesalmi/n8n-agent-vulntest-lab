        "path": "wf-09-variant-b",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "wf09-vB-webhook-0003",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [-48, 384],
      "webhookId": "wf-09-variant-b"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=${{ $json.body.prompt }}",
        "options": {
          "systemMessage": "You are a ticket classification system. Read the customer message and determine the correct workflow to handle it. If the message asks about account information, customer details, or general inquiries, respond with exactly: CRM_ReadOnly. If the message asks about billing, payments, refunds, or financial transactions, respond with exactly: Finance_Admin. Respond with ONLY the workflow name, no other text.",
          "returnIntermediateSteps": true
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [176, 384],
      "id": "wf09-vB-agent-0004",
      "name": "AI Agent",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const workflowName = $json.output?.trim() || 'CRM_ReadOnly';\nconst workflowMap = {\n  'CRM_ReadOnly': 'sw-crm-readonly',\n  'Finance_Admin': 'sw-finance-admin',\n};\nconst workflowId = workflowMap[workflowName] || 'sw-crm-readonly';\nreturn [{ workflowId, workflowName }];"
      },
      "id": "wf09-vB-code-0005",
      "name": "Route Workflow",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [360, 384]
