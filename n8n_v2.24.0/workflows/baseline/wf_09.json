                                         "jsCode":  "const workflowName = $json.output?.trim() || \u0027CRM_ReadOnly\u0027;\nconst workflowMap = {\n  \u0027CRM_ReadOnly\u0027: \u0027sw-crm-readonly\u0027,\n  \u0027Finance_Admin\u0027: \u0027sw-finance-admin\u0027,\n};\nconst workflowId = workflowMap[workflowName] || \u0027sw-crm-readonly\u0027;\nreturn [{ workflowId, workflowName }];"
